# Supabase — server-only prístup (D-026). NIKDY necommituj reálne hodnoty.
# Hodnoty získaš v Supabase → Project Settings → API.
# Skopíruj tento súbor do .env.local a doplň hodnoty (lokálne),
# na Verceli ich nastav ako Environment Variables (secrets).

# ── Next.js server-side (API routes, SSR) ─────────────────────────────────────

# Project URL (https://<ref>.supabase.co)
SUPABASE_URL=

# service_role kľúč — tajný, obchádza RLS. Len server-side, NIKDY do prehliadača.
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM rozhranie /ask (D-056) — server-only ──────────────────────────────────

# API kľúč — tajný, len server-side; stačí jeden z providerov. Bez kľúča /ask
# zobrazí, že AI asistent nie je nakonfigurovaný (zvyšok appky beží normálne).
# Provider sa auto-detekuje z dostupného kľúča (Gemini má prednosť).
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# Voliteľné: explicitný provider (gemini | anthropic | mock) a model
# (default gemini-flash-lite-latest, resp. claude-sonnet-5 pri Anthropicu).
# LLM_PROVIDER=
# LLM_MODEL=

# Voliteľné: rate limit /api/ask (D-068). Default: 20 req / 10 min per IP,
# vynucuje sa LEN v produkcii (dev/eval beží bez limitu). 0 = vypnuté.
# ASK_RATE_LIMIT_MAX=20
# ASK_RATE_LIMIT_WINDOW_MS=600000

# ── Next.js client-side (NEXT_PUBLIC_ = dostupné v prehliadači) ───────────────

# Verejná URL IFC súboru v Supabase Storage (generuje etl/ifc_upload.py).
# Voliteľné — ak chýba, 3D viewer zobrazí upozornenie.
NEXT_PUBLIC_IFC_URL=

# URL nasadeného ifc-lite viewera (apps/viewer s AimBridge), ktorý sa embedne
# cez iframe. VOLITEĽNÉ — default v kóde je verejná produkčná doména nášho
# forku (https://ifc-lite-viewer.vercel.app). Nastav len ako override:
# dev = http://localhost:3000 (ifc-lite `pnpm dev`), alebo iný deploy.
# POZOR: scope-aliasy (…-assetinspaces-projects.vercel.app) sú za Vercel SSO
# a v iframe sa nenačítajú. NIE ifclite.com — upstream most (AimBridge) nemá.
NEXT_PUBLIC_VIEWER_URL=

# ── ETL pipeline (etl/*.py) ───────────────────────────────────────────────────

# Priame Postgres pripojenie pre psycopg upserty (D-031).
# Supabase → Project Settings → Database → Connection string (URI).
# Tajné, len lokálne/CI; do prehliadača sa NIKDY nedostane.
DATABASE_URL=

# Verejná URL nasadeného Viewera — báza pre URI-link anotácie vo výkresoch (D-042 B).
# Default v kóde = produkčná Vercel URL; pre lokálny dev nastav na http://localhost:3000.
SITE_URL=
