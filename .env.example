# Supabase — server-only prístup (D-026). NIKDY necommituj reálne hodnoty.
# Hodnoty získaš v Supabase → Project Settings → API.
# Skopíruj tento súbor do .env.local a doplň hodnoty (lokálne),
# na Verceli ich nastav ako Environment Variables (secrets).

# ── Next.js server-side (API routes, SSR) ─────────────────────────────────────

# Project URL (https://<ref>.supabase.co)
SUPABASE_URL=

# service_role kľúč — tajný, obchádza RLS. Len server-side, NIKDY do prehliadača.
SUPABASE_SERVICE_ROLE_KEY=

# ── Next.js client-side (NEXT_PUBLIC_ = dostupné v prehliadači) ───────────────

# Verejná URL IFC súboru v Supabase Storage (generuje etl/ifc_upload.py).
# Voliteľné — ak chýba, 3D viewer zobrazí upozornenie.
NEXT_PUBLIC_IFC_URL=

# ── S-LLM — LLM rozhranie nad grafom (D-056/D-047) ───────────────────────────
# API-pluggable model: prepnutie providera/modelu = zmena env, žiadny redeploy.
# Kľúč sa číta LEN server-side (/api/ask), NIKDY sa nedostane do prehliadača (D-025/D-026).
# Bez LLM_MODEL/LLM_API_KEY panel „Opýtať sa" vráti jasnú env chybu (nespadne).

# anthropic | openai-compat  (default: anthropic). openai-compat = OpenAI/OpenRouter/
# Groq/Together/DeepSeek/vLLM/Ollama cez LLM_BASE_URL — všetky hovoria tým protokolom.
LLM_PROVIDER=anthropic

# Id modelu (povinné). Demo odporúčanie: claude-opus-4-8 (kvalita) alebo lacnejší model.
LLM_MODEL=

# API kľúč providera (povinné, tajné).
LLM_API_KEY=

# Override endpointu (voliteľné; default per provider — Anthropic/OpenAI). Pre
# openai-compat nastav napr. http://localhost:11434/v1 (Ollama) alebo OpenRouter URL.
LLM_BASE_URL=

# Voliteľné ladenie: max tokenov odpovede (default 1024), teplota (default 0 = deterministickejšie).
LLM_MAX_TOKENS=
LLM_TEMPERATURE=

# ── ETL pipeline (etl/*.py) ───────────────────────────────────────────────────

# Priame Postgres pripojenie pre psycopg upserty (D-031).
# Supabase → Project Settings → Database → Connection string (URI).
# Tajné, len lokálne/CI; do prehliadača sa NIKDY nedostane.
DATABASE_URL=

# Verejná URL nasadeného Viewera — báza pre URI-link anotácie vo výkresoch (D-042 B).
# Default v kóde = produkčná Vercel URL; pre lokálny dev nastav na http://localhost:3000.
SITE_URL=
