# Supabase — server-only prístup (D-026). NIKDY necommituj reálne hodnoty.
# Hodnoty získaš v Supabase → Project Settings → API.
# Skopíruj tento súbor do .env.local a doplň hodnoty (lokálne),
# na Verceli ich nastav ako Environment Variables (secrets).

# ── Next.js server-side (API routes, SSR) ─────────────────────────────────────

# Project URL (https://<ref>.supabase.co)
SUPABASE_URL=

# service_role kľúč — tajný, obchádza RLS. Len server-side, NIKDY do prehliadača.
SUPABASE_SERVICE_ROLE_KEY=

# ── Next.js client-side (NEXT_PUBLIC_ = dostupné v prehliadači) ───────────────

# Verejná URL IFC súboru v Supabase Storage (generuje etl/ifc_upload.py).
# Voliteľné — ak chýba, 3D viewer zobrazí upozornenie.
NEXT_PUBLIC_IFC_URL=

# ── ETL pipeline (etl/*.py) ───────────────────────────────────────────────────

# Priame Postgres pripojenie pre psycopg upserty (D-031).
# Supabase → Project Settings → Database → Connection string (URI).
# Tajné, len lokálne/CI; do prehliadača sa NIKDY nedostane.
DATABASE_URL=

# Verejná URL nasadeného Viewera — báza pre URI-link anotácie vo výkresoch (D-042 B).
# Default v kóde = produkčná Vercel URL; pre lokálny dev nastav na http://localhost:3000.
SITE_URL=

# ── S-LLM — prirodzený jazyk nad grafom (D-050) ───────────────────────────────
# Provider-agnostické. Prepnutie modelu = len zmena env, žiadny redeploy kódu.
# Kľúč je server-only (API route /api/ask), NIKDY sa nedostane do prehliadača.

# Adaptér API: 'anthropic' (/v1/messages) alebo 'openai-compat' (/chat/completions).
# openai-compat + LLM_BASE_URL obslúži OpenAI, OpenRouter, Groq, Together, DeepSeek,
# lokálne vLLM / Ollama / LM Studio — hocijaký model cez OpenAI-kompatibilné API.
LLM_PROVIDER=anthropic

# Id modelu (povinné) — napr. 'gpt-4o-mini', 'llama-3.3-70b-versatile',
# 'deepseek-chat' alebo konkrétny Claude model. Žiadny default v kóde.
LLM_MODEL=

# API kľúč providera (povinné). Tajný, len server-side.
LLM_API_KEY=

# Override endpointu (voliteľné). Default: anthropic=https://api.anthropic.com,
# openai-compat=https://api.openai.com/v1. Pre lokálny Ollama: http://localhost:11434/v1
LLM_BASE_URL=

# Voliteľné ladenie generovania.
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0
